# LLM Provider (claude-api | claude-vertex | claude-bedrock | gemini-api | gemini-vertex | gemini-bedrock)
LLM_PROVIDER=claude-api

# Claude API
ANTHROPIC_API_KEY=

# Google AI (Gemini API)
GOOGLE_API_KEY=

# Google Vertex AI
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# AWS Bedrock
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Prisma AIRS Scanner
PANW_AI_RUNTIME_API_KEY=

# Prisma AIRS Management API
PANW_MGMT_CLIENT_ID=
PANW_MGMT_CLIENT_SECRET=
PANW_MGMT_TSG_ID=

# Optional
SCAN_CONCURRENCY=5
PROPAGATION_DELAY_MS=10000
