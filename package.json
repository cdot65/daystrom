{
  "name": "prisma-airs-guardrail-generator",
  "version": "0.1.0",
  "description": "Automated Prisma AIRS custom topic guardrail generator with iterative refinement",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "guardrail-gen": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@cdot65/prisma-airs-sdk": "^0.2.0",
    "@inquirer/prompts": "^8.3.0",
    "@langchain/anthropic": "^1.3.21",
    "@langchain/aws": "^1.3.0",
    "@langchain/core": "^1.1.29",
    "@langchain/google-genai": "^2.1.22",
    "@langchain/google-vertexai": "^2.1.22",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "nanoid": "^5.0.0",
    "p-limit": "^6.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "msw": "^2.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
